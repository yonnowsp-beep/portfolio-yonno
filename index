    <style>
        /* ==================== VARIÁVEIS ==================== */
        :root {
            --bg-base: #07070a;
            --bg-surface: #111116;
            --bg-surface-hover: #17171e;
            
            --text-primary: #f3f4f6;
            --text-secondary: #9ca3af;
            --text-muted: #6b7280;
            
            --accent-main: #10b981; /* Verde/Esmeralda - remete a dados e crescimento */
            --accent-glow: rgba(16, 185, 129, 0.15);
            
            --border-color: #1f2937;
            
            --font-heading: 'Outfit', sans-serif;
            --font-body: 'Source Sans 3', sans-serif;
            
            --transition-smooth: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            --section-padding: 100px 0;
        }

        /* ==================== RESET & BASE ==================== */
        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
            font-family: var(--font-body);
            line-height: 1.6;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }
        ::selection { background-color: var(--accent-main); color: #fff; }
        .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
        h1, h2, h3, h4, h5, h6 { font-family: var(--font-heading); font-weight: 700; line-height: 1.2; }
        a { text-decoration: none; color: inherit; transition: var(--transition-smooth); }

        /* ==================== TYPOGRAPHY ==================== */
        .section-title { font-size: clamp(2rem, 5vw, 2.5rem); margin-bottom: 3rem; position: relative; display: inline-block; }
        .section-title::after { content: ''; position: absolute; bottom: -10px; left: 0; width: 60px; height: 3px; background-color: var(--accent-main); border-radius: 2px; }

        /* ==================== NAVBAR ==================== */
        header { position: fixed; top: 0; width: 100%; height: 80px; z-index: 100; display: flex; align-items: center; transition: var(--transition-smooth); }
        header.scrolled { background-color: rgba(7, 7, 10, 0.85); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255, 255, 255, 0.05); }
        .nav-container { display: flex; justify-content: space-between; align-items: center; width: 100%; }
        .logo { font-family: var(--font-heading); font-size: 1.5rem; font-weight: 800; color: var(--text-primary); letter-spacing: -0.5px; }
        .logo span { color: var(--accent-main); }
        .nav-links { display: flex; gap: 2.5rem; list-style: none; }
        .nav-links a { font-family: var(--font-heading); font-size: 0.95rem; color: var(--text-secondary); font-weight: 500; }
        .nav-links a:hover { color: var(--accent-main); }

        /* ==================== BUTTONS ==================== */
        .btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; padding: 14px 28px; font-family: var(--font-heading); font-weight: 600; font-size: 1rem; border-radius: 6px; transition: var(--transition-smooth); cursor: pointer; }
        .btn-primary { background-color: transparent; color: var(--accent-main); border: 1px solid var(--accent-main); }
        .btn-primary:hover { background-color: var(--accent-glow); transform: translateY(-2px); }
        .btn-secondary { background-color: var(--bg-surface); color: var(--text-primary); border: 1px solid var(--border-color); }
        .btn-secondary:hover { border-color: var(--text-secondary); background-color: var(--bg-surface-hover); transform: translateY(-2px); }

        /* ==================== HERO SECTION ==================== */
        .hero { min-height: 100vh; display: flex; align-items: center; padding-top: 80px; }
        .hero-greeting { font-family: var(--font-heading); color: var(--accent-main); font-size: 1.125rem; letter-spacing: 2px; margin-bottom: 1.5rem; display: block; }
        .hero-name { font-size: clamp(3rem, 8vw, 5rem); color: var(--text-primary); margin-bottom: 0.5rem; letter-spacing: -1px; }
        .hero-title { font-size: clamp(1.5rem, 4vw, 2.5rem); color: var(--text-secondary); margin-bottom: 2rem; font-weight: 700; }
        .hero-desc { max-width: 600px; font-size: 1.125rem; color: var(--text-secondary); margin-bottom: 3rem; }
        .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

        /* ==================== ABOUT SECTION ==================== */
        .about { padding: var(--section-padding); }
        .about-grid { display: grid; grid-template-columns: 3fr 2fr; gap: 4rem; align-items: start; }
        .about-text p { font-size: 1.1rem; color: var(--text-secondary); margin-bottom: 1.5rem; }
        .skills-container { display: flex; flex-wrap: wrap; gap: 12px; }
        .skill-tag { font-family: var(--font-heading); font-size: 0.85rem; font-weight: 500; color: var(--accent-main); background-color: var(--accent-glow); padding: 8px 16px; border-radius: 50px; border: 1px solid rgba(16, 185, 129, 0.2); transition: var(--transition-smooth); }
        .skill-tag:hover { background-color: rgba(16, 185, 129, 0.25); transform: translateY(-2px); }

        /* ==================== PROJECTS SECTION ==================== */
        .projects { padding: var(--section-padding); }
        .projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
        .project-card { background-color: var(--bg-surface); border: 1px solid var(--border-color); border-radius: 12px; padding: 2.5rem 2rem; display: flex; flex-direction: column; transition: var(--transition-smooth); }
        .project-card:hover { transform: translateY(-8px); border-color: var(--accent-main); box-shadow: 0 10px 30px -15px var(--accent-main); }
        .project-icon { color: var(--accent-main); margin-bottom: 1.5rem; }
        .project-title { font-size: 1.5rem; color: var(--text-primary); margin-bottom: 1rem; }
        .project-desc { color: var(--text-secondary); font-size: 1rem; flex-grow: 1; margin-bottom: 2rem; }
        .project-tech { display: flex; flex-wrap: wrap; gap: 1rem; font-family: var(--font-heading); font-size: 0.8rem; color: var(--text-muted); }

        /* ==================== EXPERIENCE SECTION ==================== */
        .experience { padding: var(--section-padding); }
        .timeline { position: relative; max-width: 800px; }
        .timeline::before { content: ''; position: absolute; top: 0; left: 11px; height: 100%; width: 2px; background-color: var(--border-color); }
        .timeline-item { position: relative; padding-left: 3.5rem; margin-bottom: 3.5rem; }
        .timeline-item:last-child { margin-bottom: 0; }
        .timeline-dot { position: absolute; left: 5px; top: 6px; width: 14px; height: 14px; border-radius: 50%; background-color: var(--bg-base); border: 2px solid var(--accent-main); transition: var(--transition-smooth); }
        .timeline-item:hover .timeline-dot { background-color: var(--accent-main); }
        .timeline-date { font-family: var(--font-heading); font-size: 0.85rem; color: var(--accent-main); letter-spacing: 1px; margin-bottom: 0.5rem; display: block; }
        .timeline-title { font-size: 1.25rem; color: var(--text-primary); margin-bottom: 0.25rem; }
        .timeline-company { font-size: 1rem; color: var(--text-muted); margin-bottom: 1rem; display: block; }
        .timeline-desc { color: var(--text-secondary); font-size: 1rem; }

        /* ==================== CONTACT / FOOTER ==================== */
        .contact { padding: var(--section-padding); text-align: center; max-width: 600px; margin: 0 auto; }
        .contact .section-title::after { left: 50%; transform: translateX(-50%); }
        .contact p { color: var(--text-secondary); font-size: 1.1rem; margin-bottom: 2.5rem; }
        .footer-bottom { margin-top: 100px; padding: 30px 0; border-top: 1px solid var(--border-color); text-align: center; font-size: 0.9rem; color: var(--text-muted); }

        /* ==================== ANIMATIONS ==================== */
        .fade-in { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease-out, transform 0.8s ease-out; will-change: opacity, visibility; }
        .fade-in.visible { opacity: 1; transform: translateY(0); }

        /* ==================== RESPONSIVE ==================== */
        @media (max-width: 768px) {
            .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
            .hero-actions { flex-direction: column; width: 100%; }
            .btn { width: 100%; }
        }
    </style>
</head>
